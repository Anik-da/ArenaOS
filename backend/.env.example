# ARES AI Backend Config Example
PORT=5000
NODE_ENV=development

# Authentication & JWT
JWT_SECRET=super_secret_ares_ai_jwt_key_2026_sports
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=super_secret_ares_ai_refresh_key_2026_sports
JWT_REFRESH_EXPIRES_IN=7d

# Firebase Admin Configurations
# If using file path:
FIREBASE_SERVICE_ACCOUNT_PATH=configs/firebase-service-account.json
# Or base64 encoded credential string:
FIREBASE_CREDENTIAL_BASE64=
FIREBASE_PROJECT_ID=ares-ai-sports

# Caching & Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Socket.IO & CORS Config
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# AI Platforms (Placeholders/API integrations)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Weather Integration
OPENWEATHER_API_KEY=

# Hugging Face
HUGGINGFACE_TOKEN=
